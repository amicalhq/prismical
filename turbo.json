{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "AWS_REGION",
    "S3_BUCKET_NAME",
    "S3_ENDPOINT"
  ],
  "globalPassThroughEnv": [
    "APPDATA",
    "LOCALAPPDATA",
    "USERPROFILE",
    "HOMEDRIVE",
    "HOMEPATH",
    "TEMP",
    "TMP",
    "SystemRoot",
    "windir",
    "ProgramFiles",
    "ProgramFiles(x86)",
    "ProgramW6432",
    "DOTNET_ROOT",
    "DOTNET_CLI_HOME",
    "NUGET_PACKAGES",
    "NUGET_HTTP_CACHE_PATH",
    "NUGET_CERT_REVOCATION_MODE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "bin/**",
        "native/**",
        "out/**",
        "dist/**",
        "build/**"
      ],
      "env": [
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_REGION",
        "S3_BUCKET_NAME",
        "S3_ENDPOINT",
        "POSTHOG_API_KEY",
        "POSTHOG_HOST",
        "TELEMETRY_ENABLED",
        "AUTH_CLIENT_ID",
        "AUTHORIZATION_ENDPOINT",
        "AUTH_TOKEN_ENDPOINT",
        "AUTH_REDIRECT_URI",
        "FEEDBACK_SURVEY_ID",
        "API_ENDPOINT",
        "GGML_NATIVE"
      ]
    },
    "build:native": {
      "dependsOn": [],
      "inputs": [
        "Sources/**",
        "Package.swift",
        "main.swift",
        "scripts/**",
        "src/binding/**",
        "binding.gyp",
        "whisper.cpp/**"
      ],
      "outputs": ["bin/**", "build/**", "native/**"],
      "env": ["GGML_NATIVE"],
      "cache": true
    },
    "dev:prepare": {
      "cache": false
    },
    "format:check": {},
    "lint": {
      "dependsOn": ["format:check"]
    },
    "type:check": {
      "dependsOn": ["^build", "^type:check"]
    },
    "dev": {
      "dependsOn": ["^build", "dev:prepare"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": [],
      "cache": false
    },
    "test:watch": {
      "dependsOn": [],
      "cache": false,
      "persistent": true
    },
    "test:ui": {
      "dependsOn": [],
      "cache": false,
      "persistent": true
    }
  }
}
